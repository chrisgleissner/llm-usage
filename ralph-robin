#!/usr/bin/env bash
# SPDX-License-Identifier: Apache-2.0
set -euo pipefail

APP_NAME="ralph-robin"
SCRIPT_PATH="$(readlink -f "$0" 2>/dev/null || printf '%s' "$0")"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
SCHEDULER_PATH="$SCRIPT_DIR/llm-scheduler"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/llm-usage"
CLAUDE_CACHE="$CACHE_DIR/claude-status.json"
CLAUDE_API_CACHE="$CACHE_DIR/claude-usage-api.json"
USAGE_LOG_FILE="$SCRIPT_DIR/llm-usage.log"

# shellcheck source=lib/llm-common.sh
. "$SCRIPT_DIR/lib/llm-common.sh"

TOOLS_SPEC="claude,codex"
TOOLS=()
PROMPT_TEXT=""
PROMPT_FILE=""
PROMPT_SOURCE=""
WINDOW="auto"
MIN_REMAINING="1"
POLL_INTERVAL="60"
MAX_UNAVAILABLE_WAIT="900"
RETRY_DELAYS="60,180,600"
CWD="$(pwd)"
EXEC_MODE="fresh"
TMUX_TARGET=""
COMMAND_TEMPLATE=""
AUTO_CONFIRM=1
LOG_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/ralph-robin/logs"
STATE_FILE="${XDG_CACHE_HOME:-$HOME/.cache}/ralph-robin/state.json"
DRY_RUN=0
WAKE=0
SUSPEND_UNTIL_READY=0

RUN_DIR=""
TEXT_LOG=""
EVENT_LOG=""
PROMPT_SHA=""

usage() {
  cat <<USAGE
Usage: $APP_NAME (--prompt TEXT | --prompt-file FILE) [options]

Round-robin prompt submission across local LLM CLIs. By default it keeps using
Claude while usable, switches to Codex when Claude is exhausted, then switches
back after Codex is exhausted.

Examples:
  ralph-robin --prompt-file task.md
  ralph-robin --prompt "Continue until tests pass"
  ralph-robin --tools claude,codex,copilot --prompt-file task.md
  ralph-robin --prompt-file task.md --tmux llm-work
  ralph-robin --prompt-file task.md --dry-run

Options:
  --tools LIST                Comma-separated tools in rotation (default: claude,codex).
                              Values: codex, claude, copilot.
  --prompt TEXT               Prompt text.
  --prompt-file FILE          Read prompt from FILE, preserving content.
  --window auto|5h|weekly|monthly  Usage window to gate on (default: auto).
  --min-remaining PERCENT     Minimum required remaining percentage (default: 1).
  --poll-interval SECONDS     Poll interval passed to llm-scheduler (default: 60).
  --max-unavailable-wait SECONDS  Bound inconclusive usage waits before optimistic
                              launch (default: 900; 0 waits forever).
  --retry-delays LIST         Comma-separated retry delays (default: 60,180,600).
  --no-retry                  Disable retries after failed submission.
  --cwd DIR                   Working directory for the target CLI (default: current directory).
  --fresh                     Launch a fresh CLI process through llm-scheduler (default).
  --tmux SESSION[:WINDOW]     Execute through tmux via llm-scheduler.
  --command-template TEMPLATE Override provider command; placeholders: {tool}, {prompt}, {prompt_file}, {cwd}.
  --auto-confirm              Acknowledge only known safe prompts (default).
  --no-auto-confirm           Disable automatic prompt acknowledgement.
  --log-dir DIR               Log directory (default: ~/.cache/ralph-robin/logs).
  --state-file FILE           Rotation state file (default: ~/.cache/ralph-robin/state.json).
  --wake                      Pass best-effort wake scheduling to llm-scheduler.
  --suspend-until-ready       Suspend even for the selected tool's own wait gates.
  --dry-run                   Resolve rotation and usage state without submitting.
  -h, --help                  Show this help.
USAGE
}

trim() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "$value"
}

parse_tools() {
  local raw="$1" part
  local parsed=()
  IFS=',' read -r -a parsed <<< "$raw"
  TOOLS=()
  for part in "${parsed[@]}"; do
    part="$(trim "$part")"
    case "$part" in
      codex|claude|copilot) TOOLS+=("$part") ;;
      "") ;;
      *) err "invalid tool in --tools: $part"; exit 2 ;;
    esac
  done
  if [[ "${#TOOLS[@]}" -eq 0 ]]; then
    err "--tools must name at least one tool"
    exit 2
  fi
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --tools) [[ $# -ge 2 ]] || { err "--tools requires a value"; exit 2; }; TOOLS_SPEC="$2"; shift 2 ;;
      --prompt) [[ $# -ge 2 ]] || { err "--prompt requires text"; exit 2; }; PROMPT_TEXT="$2"; PROMPT_SOURCE="inline"; shift 2 ;;
      --prompt-file) [[ $# -ge 2 ]] || { err "--prompt-file requires a file"; exit 2; }; PROMPT_FILE="$2"; PROMPT_SOURCE="file:$2"; shift 2 ;;
      --window) [[ $# -ge 2 ]] || { err "--window requires a value"; exit 2; }; WINDOW="$2"; shift 2 ;;
      --min-remaining) [[ $# -ge 2 ]] || { err "--min-remaining requires a value"; exit 2; }; MIN_REMAINING="$2"; shift 2 ;;
      --poll-interval) [[ $# -ge 2 ]] || { err "--poll-interval requires seconds"; exit 2; }; POLL_INTERVAL="$2"; shift 2 ;;
      --max-unavailable-wait) [[ $# -ge 2 ]] || { err "--max-unavailable-wait requires seconds"; exit 2; }; MAX_UNAVAILABLE_WAIT="$2"; shift 2 ;;
      --retry-delays) [[ $# -ge 2 ]] || { err "--retry-delays requires a list"; exit 2; }; RETRY_DELAYS="$2"; shift 2 ;;
      --no-retry) RETRY_DELAYS=""; shift ;;
      --cwd) [[ $# -ge 2 ]] || { err "--cwd requires a directory"; exit 2; }; CWD="$2"; shift 2 ;;
      --fresh) EXEC_MODE="fresh"; TMUX_TARGET=""; shift ;;
      --tmux) [[ $# -ge 2 ]] || { err "--tmux requires SESSION[:WINDOW]"; exit 2; }; EXEC_MODE="tmux"; TMUX_TARGET="$2"; shift 2 ;;
      --command-template) [[ $# -ge 2 ]] || { err "--command-template requires a template"; exit 2; }; COMMAND_TEMPLATE="$2"; shift 2 ;;
      --auto-confirm) AUTO_CONFIRM=1; shift ;;
      --no-auto-confirm) AUTO_CONFIRM=0; shift ;;
      --log-dir) [[ $# -ge 2 ]] || { err "--log-dir requires a directory"; exit 2; }; LOG_DIR="$2"; shift 2 ;;
      --state-file) [[ $# -ge 2 ]] || { err "--state-file requires a file"; exit 2; }; STATE_FILE="$2"; shift 2 ;;
      --wake) WAKE=1; shift ;;
      --suspend-until-ready) SUSPEND_UNTIL_READY=1; WAKE=1; shift ;;
      --dry-run) DRY_RUN=1; shift ;;
      -h|--help) usage; exit 0 ;;
      *) err "unknown option: $1"; usage >&2; exit 2 ;;
    esac
  done
}

validate_args() {
  parse_tools "$TOOLS_SPEC"
  validate_prompt_args || exit 2
  local tool
  for tool in "${TOOLS[@]}"; do
    validate_tool_window "$tool" "$WINDOW" || exit 2
  done
  validate_gate_args || exit 2
  [[ -x "$SCHEDULER_PATH" ]] || { err "llm-scheduler is not executable beside $APP_NAME"; exit 2; }
}

safe_args_json() {
  local tools_json
  tools_json="$(argv_to_json "${TOOLS[@]}")"
  jq -nc \
    --arg tools_spec "$TOOLS_SPEC" \
    --arg window "$WINDOW" \
    --arg min_remaining "$MIN_REMAINING" \
    --arg poll_interval "$POLL_INTERVAL" \
    --arg max_unavailable_wait "$MAX_UNAVAILABLE_WAIT" \
    --arg retry_delays "$RETRY_DELAYS" \
    --arg cwd "$CWD" \
    --arg mode "$EXEC_MODE" \
    --arg tmux "$TMUX_TARGET" \
    --arg prompt_source "$PROMPT_SOURCE" \
    --arg log_dir "$LOG_DIR" \
    --arg state_file "$STATE_FILE" \
    --argjson auto_confirm "$AUTO_CONFIRM" \
    --argjson dry_run "$DRY_RUN" \
    --argjson wake "$WAKE" \
    --argjson suspend_until_ready "$SUSPEND_UNTIL_READY" \
    --argjson tools "$tools_json" \
    '{tools_spec:$tools_spec,tools:$tools,window:$window,min_remaining:($min_remaining|tonumber),poll_interval:($poll_interval|tonumber),max_unavailable_wait:($max_unavailable_wait|tonumber),retry_delays:$retry_delays,cwd:$cwd,mode:$mode,tmux:$tmux,prompt_source:$prompt_source,log_dir:$log_dir,state_file:$state_file,auto_confirm:$auto_confirm,dry_run:$dry_run,wake:$wake,suspend_until_ready:$suspend_until_ready}'
}

current_index_from_state() {
  local count="${#TOOLS[@]}"
  local index
  if [[ -s "$STATE_FILE" ]]; then
    index="$(jq -r --arg tools "$TOOLS_SPEC" 'if .tools_spec == $tools then (.current_index // 0) else 0 end' "$STATE_FILE" 2>/dev/null || printf '0')"
  else
    index="0"
  fi
  [[ "$index" =~ ^[0-9]+$ ]] || index=0
  if (( index >= count )); then
    index=0
  fi
  printf '%s\n' "$index"
}

save_state() {
  local selected_index="$1"
  local selected_tool="$2"
  local tools_json
  (( DRY_RUN == 0 )) || return 0
  mkdir -p "$(dirname "$STATE_FILE")"
  chmod 700 "$(dirname "$STATE_FILE")" 2>/dev/null || true
  tools_json="$(argv_to_json "${TOOLS[@]}")"
  jq -nc \
    --arg tools_spec "$TOOLS_SPEC" \
    --arg current_tool "$selected_tool" \
    --argjson current_index "$selected_index" \
    --arg updated_at "$(date -Is)" \
    --argjson tools "$tools_json" \
    '{tools_spec:$tools_spec,tools:$tools,current_tool:$current_tool,current_index:$current_index,updated_at:$updated_at}' > "$STATE_FILE"
  chmod 600 "$STATE_FILE" 2>/dev/null || true
}

select_tool() {
  local current_index="$1"
  local count="${#TOOLS[@]}"
  local decisions=()
  local i tool snapshot decision usable reason wait_until

  for (( i=0; i<count; i++ )); do
    tool="${TOOLS[$i]}"
    snapshot="$(llm_usage_snapshot_for_tool "$tool")"
    decision="$(llm_usage_decision_for_tool "$tool" "$WINDOW" "$MIN_REMAINING" "$POLL_INTERVAL" "$snapshot")"
    decisions+=("$decision")
    log_event "usage_snapshot" "$(jq -nc --arg tool "$tool" --argjson snapshot "$snapshot" '{tool:$tool,snapshot:$snapshot}')"
    log_event "usage_decision" "$decision"
  done

  usable="$(jq -r '.usable' <<<"${decisions[$current_index]}")"
  if [[ "$usable" == "true" ]]; then
    jq -nc --argjson index "$current_index" --arg tool "${TOOLS[$current_index]}" --arg rotation_reason "current-usable" --argjson all_rate_limited false --argjson decision "${decisions[$current_index]}" \
      '{index:$index,tool:$tool,rotation_reason:$rotation_reason,all_rate_limited:$all_rate_limited,decision:$decision}'
    return 0
  fi

  for (( i=1; i<count; i++ )); do
    local next=$(( (current_index + i) % count ))
    usable="$(jq -r '.usable' <<<"${decisions[$next]}")"
    if [[ "$usable" == "true" ]]; then
      jq -nc --argjson index "$next" --arg tool "${TOOLS[$next]}" --arg rotation_reason "advanced-to-usable" --argjson all_rate_limited false --argjson decision "${decisions[$next]}" \
        '{index:$index,tool:$tool,rotation_reason:$rotation_reason,all_rate_limited:$all_rate_limited,decision:$decision}'
      return 0
    fi
  done

  local best_index="-1"
  local best_wait=""
  for (( i=0; i<count; i++ )); do
    reason="$(jq -r '.reason' <<<"${decisions[$i]}")"
    wait_until="$(jq -r '.wait_until // empty' <<<"${decisions[$i]}")"
    if [[ "$reason" == "rate-limited" && "$wait_until" =~ ^[0-9]+$ ]]; then
      if [[ -z "$best_wait" || "$wait_until" -lt "$best_wait" ]]; then
        best_wait="$wait_until"
        best_index="$i"
      fi
    fi
  done
  if [[ "$best_index" == "-1" ]]; then
    best_index="$current_index"
  fi
  jq -nc --argjson index "$best_index" --arg tool "${TOOLS[$best_index]}" --arg rotation_reason "all-unusable" --argjson all_rate_limited "$([[ -n "$best_wait" ]] && printf true || printf false)" --argjson decision "${decisions[$best_index]}" \
    '{index:$index,tool:$tool,rotation_reason:$rotation_reason,all_rate_limited:$all_rate_limited,decision:$decision}'
}

# Fills the SCHEDULER_ARGS global with the llm-scheduler invocation for the
# selected tool. The child scheduler writes into a scheduler/ subdirectory of
# this run so all logs for one rotation stay in one place.
SCHEDULER_ARGS=()
build_scheduler_args() {
  local selected_tool="$1"
  local force_suspend="$2"
  SCHEDULER_ARGS=(
    "$SCHEDULER_PATH"
    --tool "$selected_tool"
    --prompt-file "$RUN_DIR/prompt.txt"
    --window "$WINDOW"
    --min-remaining "$MIN_REMAINING"
    --poll-interval "$POLL_INTERVAL"
    --max-unavailable-wait "$MAX_UNAVAILABLE_WAIT"
    --cwd "$CWD"
    --log-dir "$RUN_DIR"
    --run-dir "$RUN_DIR/scheduler"
  )

  if [[ -n "$RETRY_DELAYS" ]]; then
    SCHEDULER_ARGS+=(--retry-delays "$RETRY_DELAYS")
  else
    SCHEDULER_ARGS+=(--no-retry)
  fi
  if (( AUTO_CONFIRM == 1 )); then
    SCHEDULER_ARGS+=(--auto-confirm)
  else
    SCHEDULER_ARGS+=(--no-auto-confirm)
  fi
  if [[ "$EXEC_MODE" == "tmux" ]]; then
    SCHEDULER_ARGS+=(--tmux "$TMUX_TARGET")
  else
    SCHEDULER_ARGS+=(--fresh)
  fi
  if [[ -n "$COMMAND_TEMPLATE" ]]; then
    SCHEDULER_ARGS+=(--command-template "$COMMAND_TEMPLATE")
  fi
  if (( WAKE == 1 )); then
    SCHEDULER_ARGS+=(--wake)
  fi
  if (( SUSPEND_UNTIL_READY == 1 || force_suspend == 1 )); then
    SCHEDULER_ARGS+=(--suspend-until-ready)
  fi
}

run_scheduler() {
  local status=0
  log_event "scheduler_command" "$(jq -nc --argjson argv "$(argv_to_json "${SCHEDULER_ARGS[@]}")" '{argv:$argv}')"
  set +e
  "${SCHEDULER_ARGS[@]}"
  status=$?
  set -e
  log_event "scheduler_result" "$(jq -nc --argjson status "$status" '{status:$status}')"
  return "$status"
}

main() {
  parse_args "$@"
  validate_args
  need jq
  need date
  need sha256sum
  need awk
  need python3

  setup_run_logs "ralph-robin"
  load_prompt
  log_text "start tools=$TOOLS_SPEC cwd=$CWD"
  log_text "run directory: $RUN_DIR"
  log_event "start" "$(safe_args_json)"
  log_event "prompt" "$(jq -nc --arg source "$PROMPT_SOURCE" --arg sha256 "$PROMPT_SHA" --rawfile prompt "$RUN_DIR/prompt.txt" '{source:$source,sha256:$sha256,prompt:$prompt}')"

  local current_index selection selected_index selected_tool rotation_reason all_rate_limited wait_until wait_display status
  current_index="$(current_index_from_state)"
  log_event "state" "$(jq -nc --arg state_file "$STATE_FILE" --argjson current_index "$current_index" '{state_file:$state_file,current_index:$current_index}')"
  selection="$(select_tool "$current_index")"
  selected_index="$(jq -r '.index' <<<"$selection")"
  selected_tool="$(jq -r '.tool' <<<"$selection")"
  rotation_reason="$(jq -r '.rotation_reason' <<<"$selection")"
  all_rate_limited="$(jq -r '.all_rate_limited' <<<"$selection")"
  wait_until="$(jq -r '.decision.wait_until // empty' <<<"$selection")"
  log_event "selection" "$selection"
  log_text "selected provider=$selected_tool reason=$rotation_reason all_rate_limited=$all_rate_limited"

  printf 'ralph-robin: logs: %s\n' "$RUN_DIR"
  printf 'ralph-robin: selected %s (%s)\n' "$selected_tool" "$rotation_reason"
  if [[ "$all_rate_limited" == "true" ]]; then
    if [[ "$wait_until" =~ ^[0-9]+$ ]]; then
      wait_display="$(format_local_epoch "$wait_until") (epoch $wait_until)"
    else
      wait_display="unknown"
    fi
    printf 'ralph-robin: all configured tools are rate-limited; suspending via llm-scheduler until %s\n' "$wait_display"
  fi

  save_state "$selected_index" "$selected_tool"

  if (( DRY_RUN == 1 )); then
    log_event "final" '{"status":"dry-run"}'
    printf 'dry-run: no prompt submitted\n'
    exit 0
  fi

  build_scheduler_args "$selected_tool" "$([[ "$all_rate_limited" == "true" ]] && printf 1 || printf 0)"
  if run_scheduler; then
    status=0
    log_event "final" '{"status":"success"}'
  else
    status=$?
    log_event "final" "$(jq -nc --argjson status "$status" '{status:"failed",exit_code:$status}')"
  fi
  exit "$status"
}

main "$@"
