#!/usr/bin/env bash
# SPDX-License-Identifier: Apache-2.0
set -euo pipefail

APP_NAME="llm-scheduler"
SCRIPT_PATH="$(readlink -f "$0" 2>/dev/null || printf '%s' "$0")"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/llm-usage"
CLAUDE_CACHE="$CACHE_DIR/claude-status.json"
CLAUDE_API_CACHE="$CACHE_DIR/claude-usage-api.json"
USAGE_LOG_FILE="$SCRIPT_DIR/llm-usage.log"

# shellcheck source=lib/llm-common.sh
. "$SCRIPT_DIR/lib/llm-common.sh"

TOOL=""
PROMPT_TEXT=""
PROMPT_FILE=""
PROMPT_SOURCE=""
AT_TIME=""
WINDOW="auto"
MIN_REMAINING="1"
POLL_INTERVAL="60"
MAX_UNAVAILABLE_WAIT="900"
RETRY_DELAYS="60,180,600"
CWD="$(pwd)"
EXEC_MODE="fresh"
TMUX_TARGET=""
COMMAND_TEMPLATE=""
AUTO_CONFIRM=1
LOG_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/llm-scheduler/logs"
DRY_RUN=0
WAKE=0
WAKE_TEST=0
SUSPEND_UNTIL_READY=0
PRE_SUSPEND_CONFIRMATION_SECONDS="${LLM_SCHEDULER_PRE_SUSPEND_CONFIRMATION_SECONDS:-5}"

NOT_BEFORE_EPOCH=""
RUN_DIR=""
TEXT_LOG=""
EVENT_LOG=""
PROMPT_SHA=""
# Tracks the latest OS wake target already armed, so a long poll loop under --wake
# does not arm a fresh transient systemd timer on every iteration.
WAKE_ARMED_TARGET=0

usage() {
  cat <<USAGE
Usage: $APP_NAME --tool codex|claude|copilot (--prompt TEXT | --prompt-file FILE) [options]

Submit a prompt to a local LLM CLI as soon as shared llm-usage data says it is usable.

Examples:
  llm-scheduler --tool codex --prompt-file task.md
  llm-scheduler --tool claude --prompt "Continue the work in this repo until CI is green"
  llm-scheduler --tool copilot --prompt-file task.md --retry-delays 60,180,600
  llm-scheduler --tool codex --prompt-file task.md --at "23:05"
  llm-scheduler --tool codex --prompt-file task.md --tmux llm-work
  llm-scheduler --tool codex --prompt-file task.md --wake
  llm-scheduler --tool claude --prompt-file task.md --window 5h --suspend-until-ready
  llm-scheduler --tool codex --prompt-file task.md --dry-run

Options:
  --tool TOOL                 codex, claude, or copilot.
  --prompt TEXT               Prompt text.
  --prompt-file FILE          Read prompt from FILE, preserving content.
  --at TIME, --not-before TIME  Do not submit before date -d compatible local time.
  --window auto|5h|weekly|monthly  Usage window to gate on (default: auto).
  --min-remaining PERCENT     Minimum required remaining percentage (default: 1).
  --poll-interval SECONDS     Poll interval when reset data is unavailable (default: 60).
  --max-unavailable-wait SECONDS  Max time to keep polling while usage data cannot be
                              measured (no network, transient API failure, inconclusive
                              data) before launching optimistically and letting the tool's
                              own rate-limit handling and --retry-delays take over.
                              0 waits forever (default: 900). Does not apply to a known
                              rate-limit reset, which always waits for the real reset time.
  --retry-delays LIST         Comma-separated retry delays (default: 60,180,600).
  --no-retry                  Disable retries after failed submission.
  --cwd DIR                   Working directory for the target CLI (default: current directory).
  --fresh                     Launch a fresh CLI process (default).
  --tmux SESSION[:WINDOW]     Execute via tmux instead of foreground process.
  --command-template TEMPLATE Override provider command; placeholders: {tool}, {prompt}, {prompt_file}, {cwd}.
  --auto-confirm              Acknowledge only known safe prompts (default).
  --no-auto-confirm           Disable automatic prompt acknowledgement.
  --log-dir DIR               Log directory (default: ~/.cache/llm-scheduler/logs).
  --run-dir DIR               Reuse/write one specific run directory.
  --dry-run                   Resolve state and command plan without submitting.
  --wake                      Best-effort wake scheduling diagnostics/logging.
  --suspend-until-ready       Arm a wake timer for the next reset/not-before time,
                              suspend now, and run this scheduler after wake.
  --wake-test                 Print wake capability diagnostics and exit.
  -h, --help                  Show this help.
USAGE
}

# A usage decision is "undeterminable" when we cannot positively measure the
# remaining quota: no network, a transient API failure, an unsupported window,
# inconclusive data, or any provider-specific unavailable reason. These are
# distinct from "rate-limited", which carries a real reset epoch to wait for.
# Invert logic: only "rate-limited" is NOT undetermined.
is_undetermined_reason() {
  [[ "${1:-}" != "rate-limited" ]]
}

safe_args_json() {
  jq -nc \
    --arg tool "$TOOL" \
    --arg window "$WINDOW" \
    --arg min_remaining "$MIN_REMAINING" \
    --arg poll_interval "$POLL_INTERVAL" \
    --arg max_unavailable_wait "$MAX_UNAVAILABLE_WAIT" \
    --arg retry_delays "$RETRY_DELAYS" \
    --arg cwd "$CWD" \
    --arg mode "$EXEC_MODE" \
    --arg tmux "$TMUX_TARGET" \
    --arg prompt_source "$PROMPT_SOURCE" \
    --arg log_dir "$LOG_DIR" \
    --argjson auto_confirm "$AUTO_CONFIRM" \
    --argjson dry_run "$DRY_RUN" \
    --argjson wake "$WAKE" \
    --argjson suspend_until_ready "$SUSPEND_UNTIL_READY" \
    '{tool:$tool,window:$window,min_remaining:($min_remaining|tonumber),poll_interval:($poll_interval|tonumber),max_unavailable_wait:($max_unavailable_wait|tonumber),retry_delays:$retry_delays,cwd:$cwd,mode:$mode,tmux:$tmux,prompt_source:$prompt_source,log_dir:$log_dir,auto_confirm:$auto_confirm,dry_run:$dry_run,wake:$wake,suspend_until_ready:$suspend_until_ready}'
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --tool) [[ $# -ge 2 ]] || { err "--tool requires a value"; exit 2; }; TOOL="$2"; shift 2 ;;
      --prompt) [[ $# -ge 2 ]] || { err "--prompt requires text"; exit 2; }; PROMPT_TEXT="$2"; PROMPT_SOURCE="inline"; shift 2 ;;
      --prompt-file) [[ $# -ge 2 ]] || { err "--prompt-file requires a file"; exit 2; }; PROMPT_FILE="$2"; PROMPT_SOURCE="file:$2"; shift 2 ;;
      --at|--not-before) [[ $# -ge 2 ]] || { err "$1 requires a time"; exit 2; }; AT_TIME="$2"; shift 2 ;;
      --window) [[ $# -ge 2 ]] || { err "--window requires a value"; exit 2; }; WINDOW="$2"; shift 2 ;;
      --min-remaining) [[ $# -ge 2 ]] || { err "--min-remaining requires a value"; exit 2; }; MIN_REMAINING="$2"; shift 2 ;;
      --poll-interval) [[ $# -ge 2 ]] || { err "--poll-interval requires seconds"; exit 2; }; POLL_INTERVAL="$2"; shift 2 ;;
      --max-unavailable-wait) [[ $# -ge 2 ]] || { err "--max-unavailable-wait requires seconds"; exit 2; }; MAX_UNAVAILABLE_WAIT="$2"; shift 2 ;;
      --retry-delays) [[ $# -ge 2 ]] || { err "--retry-delays requires a list"; exit 2; }; RETRY_DELAYS="$2"; shift 2 ;;
      --no-retry) RETRY_DELAYS=""; shift ;;
      --cwd) [[ $# -ge 2 ]] || { err "--cwd requires a directory"; exit 2; }; CWD="$2"; shift 2 ;;
      --fresh) EXEC_MODE="fresh"; TMUX_TARGET=""; shift ;;
      --tmux) [[ $# -ge 2 ]] || { err "--tmux requires SESSION[:WINDOW]"; exit 2; }; EXEC_MODE="tmux"; TMUX_TARGET="$2"; shift 2 ;;
      --command-template) [[ $# -ge 2 ]] || { err "--command-template requires a template"; exit 2; }; COMMAND_TEMPLATE="$2"; shift 2 ;;
      --auto-confirm) AUTO_CONFIRM=1; shift ;;
      --no-auto-confirm) AUTO_CONFIRM=0; shift ;;
      --log-dir) [[ $# -ge 2 ]] || { err "--log-dir requires a directory"; exit 2; }; LOG_DIR="$2"; shift 2 ;;
      --run-dir) [[ $# -ge 2 ]] || { err "--run-dir requires a directory"; exit 2; }; RUN_DIR="$2"; shift 2 ;;
      --dry-run) DRY_RUN=1; shift ;;
      --wake) WAKE=1; shift ;;
      --suspend-until-ready) SUSPEND_UNTIL_READY=1; WAKE=1; shift ;;
      --wake-test) WAKE_TEST=1; shift ;;
      -h|--help) usage; exit 0 ;;
      *) err "unknown option: $1"; usage >&2; exit 2 ;;
    esac
  done
}

validate_args() {
  if [[ "$WAKE_TEST" -eq 1 ]]; then
    return 0
  fi
  case "$TOOL" in
    codex|claude|copilot) ;;
    "") err "--tool is required"; exit 2 ;;
    *) err "invalid --tool: $TOOL"; exit 2 ;;
  esac
  validate_prompt_args || exit 2
  validate_tool_window "$TOOL" "$WINDOW" || exit 2
  validate_gate_args || exit 2
  is_integer "$PRE_SUSPEND_CONFIRMATION_SECONDS" || { err "LLM_SCHEDULER_PRE_SUSPEND_CONFIRMATION_SECONDS must be integer seconds"; exit 2; }
  # Validate --at / --not-before early so an invalid time exits before
  # setup_run_logs creates a run directory.
  if [[ -n "$AT_TIME" ]]; then
    NOT_BEFORE_EPOCH="$(date -d "$AT_TIME" +%s 2>/dev/null)" || {
      err "could not parse --at/--not-before time: $AT_TIME"
      exit 2
    }
  else
    NOT_BEFORE_EPOCH=""
  fi
}

parse_not_before_epoch() {
  if [[ -n "${NOT_BEFORE_EPOCH:-}" ]]; then
    printf '%s\n' "$NOT_BEFORE_EPOCH"
  else
    now_epoch
  fi
}

scheduler_usage_snapshot() {
  llm_usage_snapshot_for_tool "$TOOL"
}

usage_decision() {
  local snapshot="$1"
  llm_usage_decision_for_tool "$TOOL" "$WINDOW" "$MIN_REMAINING" "$POLL_INTERVAL" "$snapshot"
}

sleep_until() {
  local target="$1" now seconds
  now="$(now_epoch)"
  seconds=$(( target - now ))
  (( seconds > 0 )) || return 0
  sleep "$seconds"
}

provider_default_argv_json() {
  case "$TOOL" in
    codex)
      jq -nc --arg prompt "$PROMPT_TEXT" --arg cwd "$CWD" '["codex","exec","-C",$cwd,$prompt]'
      ;;
    claude)
      jq -nc --arg prompt "$PROMPT_TEXT" '["claude","--dangerously-skip-permissions","--print",$prompt]'
      ;;
    copilot)
      jq -nc --arg prompt "$PROMPT_TEXT" --arg cwd "$CWD" '["copilot","-C",$cwd,"--prompt",$prompt]'
      ;;
  esac
}

template_argv_json() {
  local template="$1"
  TEMPLATE="$template" TOOL="$TOOL" PROMPT="$PROMPT_TEXT" PROMPT_FILE="$RUN_DIR/prompt.txt" CWD_VALUE="$CWD" python3 - <<'PY'
import json
import os
import shlex
import sys

try:
    parts = shlex.split(os.environ["TEMPLATE"])
except ValueError as exc:
    print(str(exc), file=sys.stderr)
    sys.exit(2)

values = {
    "{tool}": os.environ.get("TOOL", ""),
    "{prompt}": os.environ.get("PROMPT", ""),
    "{prompt_file}": os.environ.get("PROMPT_FILE", ""),
    "{cwd}": os.environ.get("CWD_VALUE", ""),
}
out = []
for part in parts:
    for key, value in values.items():
        part = part.replace(key, value)
    out.append(part)
print(json.dumps(out))
PY
}

command_argv_json() {
  if [[ -n "$COMMAND_TEMPLATE" ]]; then
    template_argv_json "$COMMAND_TEMPLATE"
  else
    provider_default_argv_json
  fi
}

scheduler_model_description() {
  if [[ -n "$COMMAND_TEMPLATE" ]]; then
    printf '%s\n' 'from command template'
    return 0
  fi
  case "$TOOL" in
    codex) printf '%s\n' 'Codex CLI default/configured model' ;;
    claude) printf '%s\n' 'Claude Code default/configured model' ;;
    copilot) printf '%s\n' 'GitHub Copilot CLI default/configured model' ;;
  esac
}

print_pre_suspend_confirmation() {
  local target_epoch="$1"
  local unit="$2"
  local reason="$3"
  local seconds="$PRE_SUSPEND_CONFIRMATION_SECONDS"
  local prompt_display model_display wake_display

  if [[ -n "$PROMPT_FILE" ]]; then
    prompt_display="$PROMPT_FILE (saved copy: $RUN_DIR/prompt.txt)"
  else
    prompt_display="inline prompt (saved copy: $RUN_DIR/prompt.txt)"
  fi
  model_display="$(scheduler_model_description)"
  wake_display="$(format_local_epoch "$target_epoch")"

  printf 'suspend-until-ready armed\n'
  printf '  wake/run at: %s (epoch %s)\n' "$wake_display" "$target_epoch"
  printf '  reason: %s\n' "$reason"
  printf '  tool: %s\n' "$TOOL"
  printf '  model: %s\n' "$model_display"
  printf '  prompt: %s\n' "$prompt_display"
  printf '  directory: %s\n' "$CWD"
  printf '  timer unit: %s\n' "$unit"
  printf '  logs: %s\n' "$RUN_DIR"
  if (( seconds > 0 )); then
    printf 'suspending in %s seconds...\n' "$seconds"
    sleep "$seconds"
  fi
}

run_fresh() {
  local argv_json="$1"
  local output_file="$2"
  local status_file="$3"
  AUTO_CONFIRM_VALUE="$AUTO_CONFIRM" CWD_VALUE="$CWD" ARGV_JSON="$argv_json" OUTPUT_FILE="$output_file" STATUS_FILE="$status_file" python3 - <<'PY'
import json
import os
import pty
import re
import select
import signal
import sys
import time

argv = json.loads(os.environ["ARGV_JSON"])
cwd = os.environ["CWD_VALUE"]
output_file = os.environ["OUTPUT_FILE"]
status_file = os.environ["STATUS_FILE"]
auto_confirm = os.environ.get("AUTO_CONFIRM_VALUE") == "1"
timeout = int(os.environ.get("LLM_SCHEDULER_PTY_TIMEOUT", "3600"))

safe_prompts = (
    "Confirm folder trust",
    "Do you trust the files in this folder?",
)

pid, fd = pty.fork()
if pid == 0:
    try:
        os.chdir(cwd)
    except OSError:
        pass
    os.execvp(argv[0], argv)

parts = []
trust_sent = False
exit_code = 124
eof = False
start = time.time()
out_fh = open(output_file, "w", encoding="utf-8")

def clean(text):
    text = text.replace("\r", "\n").replace("\a", "")
    return re.sub(r"\x1b\[[0-9;?]*[ -/]*[@-~]", "", text)

def reap_status(status):
    if os.WIFEXITED(status):
        return os.WEXITSTATUS(status)
    if os.WIFSIGNALED(status):
        return 128 + os.WTERMSIG(status)
    return None

while True:
    if time.time() - start > timeout:
        break
    ready, _, _ = select.select([fd], [], [], 0.2)
    if fd in ready:
        try:
            chunk = os.read(fd, 65536)
        except OSError:
            eof = True
            break
        if not chunk:
            eof = True
            break
        text = chunk.decode("utf-8", "replace")
        parts.append(text)
        out_fh.write(clean(text))
        out_fh.flush()
        combined = "".join(parts)
        if auto_confirm and not trust_sent and any(p in combined for p in safe_prompts):
            os.write(fd, b"\r")
            trust_sent = True
    try:
        done, status = os.waitpid(pid, os.WNOHANG)
    except ChildProcessError:
        done = pid
        status = 0
    if done == pid:
        code = reap_status(status)
        if code is not None:
            exit_code = code
        break

if exit_code == 124:
    # On Linux a child's PTY fds close (EOF/EIO on the master) slightly before
    # the process becomes waitable, so a single WNOHANG here can miss a child
    # that exited cleanly and misreport 124. After EOF, poll briefly for the
    # real status before treating the run as timed out.
    deadline = time.time() + (5.0 if eof else 0.0)
    while True:
        try:
            done, status = os.waitpid(pid, os.WNOHANG)
        except ChildProcessError:
            break
        if done == pid:
            code = reap_status(status)
            if code is not None:
                exit_code = code
            break
        if time.time() >= deadline:
            break
        time.sleep(0.01)

if exit_code == 124:
    for sig in (signal.SIGTERM, signal.SIGKILL):
        try:
            os.kill(pid, sig)
        except ProcessLookupError:
            break
        time.sleep(0.2)

text = clean("".join(parts))
out_fh.seek(0)
out_fh.truncate()
out_fh.write(text)
out_fh.close()
with open(status_file, "w", encoding="utf-8") as fh:
    fh.write(str(exit_code))
sys.exit(exit_code)
PY
}

run_tmux() {
  local argv_json="$1"
  local output_file="$2"
  local status_file="$3"
  have_cmd tmux || {
    printf 'tmux not installed\n' > "$output_file"
    printf '127' > "$status_file"
    return 127
  }
  local session window target cmd_file cmd_invocation command_line waited
  if [[ "$TMUX_TARGET" == *:* ]]; then
    session="${TMUX_TARGET%%:*}"
    window="${TMUX_TARGET#*:}"
    if [[ -z "$session" || -z "$window" ]]; then
      printf 'invalid tmux target: %s\n' "$TMUX_TARGET" > "$output_file"
      printf '2' > "$status_file"
      return 2
    fi
  else
    session="$TMUX_TARGET"
    window="llm-scheduler"
  fi
  target="$session:$window"
  cmd_file="$RUN_DIR/tmux-command.sh"
  command_line="$(argv_json_to_command_line "$argv_json")"
  {
    printf '%s\n' '#!/usr/bin/env bash'
    printf '%s\n' 'set -euo pipefail'
    printf 'cd %q\n' "$CWD"
    printf '%s\n' 'set +e'
    printf '%s\n' "$command_line"
    printf '%s\n' 'status=$?'
    # These single-quoted strings are literal lines of the generated script, not
    # expansions in this script.
    # shellcheck disable=SC2016
    printf 'printf %%s "$status" > %q\n' "$status_file"
    # shellcheck disable=SC2016
    printf '%s\n' 'exit "$status"'
  } > "$cmd_file"
  chmod 700 "$cmd_file"
  printf -v cmd_invocation 'bash %q' "$cmd_file"
  if ! tmux has-session -t "$session" 2>/dev/null; then
    tmux new-session -d -s "$session" -n "$window" "$cmd_invocation"
  elif ! tmux list-windows -t "$session" -F '#W' | grep -Fxq "$window"; then
    tmux new-window -d -t "$session" -n "$window" "$cmd_invocation"
  else
    tmux send-keys -t "$target" "$cmd_invocation" C-m
  fi
  waited=0
  while [[ ! -s "$status_file" && "$waited" -lt "${LLM_SCHEDULER_TMUX_TIMEOUT:-3600}" ]]; do
    tmux capture-pane -p -t "$target" > "$output_file" 2>/dev/null || true
    sleep 1
    waited=$(( waited + 1 ))
  done
  tmux capture-pane -p -t "$target" > "$output_file" 2>/dev/null || true
  if [[ ! -s "$status_file" ]]; then
    printf '124' > "$status_file"
  fi
}

output_is_retryable() {
  local status="$1"
  local output_file="$2"
  # A non-zero exit is the primary, reliable signal: most CLIs exit non-zero on
  # rate-limit/overload.
  if [[ "$status" -ne 0 ]]; then
    return 0
  fi
  # On a clean exit, only retry for specific provider rate-limit/overload phrases.
  # The previous broad set (bare "timeout", "quota", "try again", "temporar")
  # matched ordinary successful agent output (e.g. a prompt about fixing a
  # "timeout bug"), causing expensive autonomous runs to be re-submitted. Keep
  # patterns specific enough that they rarely appear outside an error banner.
  if grep -Eiq 'rate[ _-]?limited|rate[ _-]?limit (exceeded|reached|hit)|too many requests|http[ /?]429|status 429|429 too many requests|quota (exceeded|reached)|usage limit (exceeded|reached)|overloaded|service unavailable|temporarily unavailable|try again later' "$output_file"; then
    return 0
  fi
  return 1
}

submit_once() {
  local attempt="$1" argv_json="$2" output_file status_file status
  output_file="$RUN_DIR/attempt-${attempt}.out"
  status_file="$RUN_DIR/attempt-${attempt}.status"
  log_text "attempt $attempt command: $(jq -c . <<<"$argv_json")"
  log_text "attempt $attempt output: $output_file"
  log_text "tail attempt $attempt: tail -f '$output_file'"
  log_event "command_plan" "$(jq -nc --argjson argv "$argv_json" --arg mode "$EXEC_MODE" '{mode:$mode, argv:$argv}')"
  if [[ "$EXEC_MODE" == "tmux" ]]; then
    run_tmux "$argv_json" "$output_file" "$status_file" || true
  else
    run_fresh "$argv_json" "$output_file" "$status_file" || true
  fi
  # 124 = timeout/incomplete (same code run_fresh uses for a timed-out PTY).
  # Use it as the synthetic status when the runner never wrote the status file,
  # so submit_once can log a controlled failure rather than dying via set -e.
  if [[ ! -s "$status_file" ]]; then
    printf '124' > "$status_file"
  fi
  [[ -f "$output_file" ]] || : > "$output_file"
  status="$(<"$status_file")"
  # status must be an integer; guard against corrupt/empty reads.
  [[ "$status" =~ ^[0-9]+$ ]] || status=124
  cat "$output_file" >> "$TEXT_LOG"
  log_event "attempt_result" "$(jq -nc --argjson attempt "$attempt" --argjson status "$status" --rawfile output "$output_file" '{attempt:$attempt,status:$status,output:$output}')"
  if output_is_retryable "$status" "$output_file"; then
    return 1
  fi
  return 0
}

retry_delays_array() {
  local list="${1:-}"
  RETRY_ARRAY=()
  [[ -n "$list" ]] || return 0
  IFS=',' read -r -a RETRY_ARRAY <<< "$list"
}

wake_diagnostics_json() {
  local has_systemd_run=0 has_rtcwake=0 user_systemd="unknown" systemd_state
  have_cmd systemd-run && has_systemd_run=1
  have_cmd rtcwake && has_rtcwake=1
  if have_cmd systemctl; then
    set +e
    systemd_state="$(systemctl --user is-system-running 2>/dev/null)"
    set -e
    case "${systemd_state:-}" in
      running)  user_systemd="running" ;;
      degraded) user_systemd="degraded" ;;
      "")       user_systemd="unknown" ;;
      *)        user_systemd="$systemd_state" ;;
    esac
  fi
  jq -nc --argjson systemd_run "$has_systemd_run" --argjson rtcwake "$has_rtcwake" --arg user_systemd "$user_systemd" \
    '{systemd_run:($systemd_run==1),rtcwake:($rtcwake==1),user_systemd:$user_systemd,note:"wake is best effort and depends on firmware, kernel, RTC, and systemd support"}'
}

print_wake_test() {
  wake_diagnostics_json | jq .
}

log_wake_plan() {
  local target_epoch="$1"
  local wake_epoch cmd unit output status now lead min_lead
  (( WAKE == 1 )) || return 0
  now="$(now_epoch)"
  # An OS wake timer only recovers from an *unexpected* suspend during the wait.
  # Short polls (we are already awake and sleeping in-process) do not need one,
  # and arming one per poll iteration would leak hundreds of transient units over
  # a long rate-limit wait. Only arm when there is meaningful lead time, and never
  # re-arm for a target we have already covered.
  min_lead="${LLM_SCHEDULER_WAKE_MIN_LEAD:-120}"
  lead=$(( target_epoch - now ))
  if (( lead < min_lead )); then
    return 0
  fi
  if (( target_epoch <= WAKE_ARMED_TARGET )); then
    return 0
  fi
  wake_epoch=$(( target_epoch - 120 ))
  (( wake_epoch > now )) || wake_epoch="$target_epoch"
  unit="llm-scheduler-wake-$(date +%s)"
  cmd="systemd-run --user --unit=$unit --on-calendar=@$wake_epoch --timer-property=WakeSystem=true true"
  log_event "wake_diagnostics" "$(wake_diagnostics_json)"
  log_text "wake best-effort command: $cmd"
  log_text "rtcwake fallback, if appropriate and run manually with privileges: sudo rtcwake -m no -t $wake_epoch"
  if (( DRY_RUN == 0 )) && have_cmd systemd-run; then
    set +e
    output="$(systemd-run --user --unit="$unit" --on-calendar="@$wake_epoch" --timer-property=WakeSystem=true true 2>&1)"
    status=$?
    set -e
    log_text "wake systemd-run status=$status output=$output"
    log_event "wake_attempt" "$(jq -nc --arg unit "$unit" --argjson wake_epoch "$wake_epoch" --argjson status "$status" --arg output "$output" '{method:"systemd-run",unit:$unit,wake_epoch:$wake_epoch,status:$status,output:$output}')"
  fi
  WAKE_ARMED_TARGET="$target_epoch"
}

scheduler_resume_argv_json() {
  local auto_flag mode_flag retry_parts=()
  if (( AUTO_CONFIRM == 1 )); then
    auto_flag="--auto-confirm"
  else
    auto_flag="--no-auto-confirm"
  fi
  if [[ "$EXEC_MODE" == "tmux" ]]; then
    mode_flag="--tmux"
  else
    mode_flag="--fresh"
  fi
  if [[ -n "$RETRY_DELAYS" ]]; then
    retry_parts=(--retry-delays "$RETRY_DELAYS")
  else
    retry_parts=(--no-retry)
  fi

  local args=(
    "$SCRIPT_PATH"
    --tool "$TOOL"
    --prompt-file "$RUN_DIR/prompt.txt"
    --window "$WINDOW"
    --min-remaining "$MIN_REMAINING"
    --poll-interval "$POLL_INTERVAL"
    --max-unavailable-wait "$MAX_UNAVAILABLE_WAIT"
    --cwd "$CWD"
    "$auto_flag"
    --log-dir "$LOG_DIR"
    --run-dir "$RUN_DIR"
  )
  args+=("${retry_parts[@]}")
  if [[ "$mode_flag" == "--tmux" ]]; then
    args+=(--tmux "$TMUX_TARGET")
  else
    args+=(--fresh)
  fi
  if [[ -n "$COMMAND_TEMPLATE" ]]; then
    args+=(--command-template "$COMMAND_TEMPLATE")
  fi

  argv_to_json "${args[@]}"
}

schedule_resume_and_suspend() {
  local target_epoch="$1"
  local reason="$2"
  local unit output status argv_json command_line env_path now lead min_lead

  if ! have_cmd systemd-run; then
    log_text "suspend-until-ready unavailable: systemd-run missing"
    log_event "suspend_schedule_failed" '{"reason":"missing-systemd-run"}'
    return 1
  fi
  if ! have_cmd systemctl; then
    log_text "suspend-until-ready unavailable: systemctl missing"
    log_event "suspend_schedule_failed" '{"reason":"missing-systemctl"}'
    return 1
  fi

  # Minimum lead guard: a target too close to now causes pointless suspend churn
  # or a near-past systemd-run failure. Fall back to in-process waiting instead.
  min_lead="${LLM_SCHEDULER_SUSPEND_MIN_LEAD:-120}"
  now="$(now_epoch)"
  lead=$(( target_epoch - now ))
  if (( lead < min_lead )); then
    log_text "suspend-until-ready lead=${lead}s < min_lead=${min_lead}s; falling back to in-process wait"
    log_event "suspend_schedule_failed" "$(jq -nc --argjson lead "$lead" --argjson min_lead "$min_lead" '{reason:"insufficient-lead",lead:$lead,min_lead:$min_lead}')"
    return 1
  fi

  unit="llm-scheduler-resume-${TOOL}-$(date +%s)"
  argv_json="$(scheduler_resume_argv_json)"
  command_line="$(argv_json_to_command_line "$argv_json")"
  env_path="${PATH:-/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin}"

  log_text "suspend-until-ready scheduling unit=$unit target=$target_epoch reason=$reason"
  log_event "suspend_schedule_plan" "$(jq -nc --arg unit "$unit" --arg reason "$reason" --argjson target_epoch "$target_epoch" --argjson argv "$argv_json" '{unit:$unit,reason:$reason,target_epoch:$target_epoch,argv:$argv}')"

  if (( DRY_RUN == 1 )); then
    log_text "dry-run suspend-until-ready command: systemd-run --user --unit=$unit --on-calendar=@$target_epoch --timer-property=WakeSystem=true --setenv=PATH=... /bin/bash -lc '$command_line'"
    log_event "suspend_schedule_dry_run" "$(jq -nc --arg unit "$unit" --arg command "$command_line" --argjson target_epoch "$target_epoch" '{unit:$unit,target_epoch:$target_epoch,command:$command}')"
    printf 'dry-run: would schedule %s.timer at epoch %s (%s); logs: %s\n' \
      "$unit" "$target_epoch" "$(format_local_epoch "$target_epoch")" "$RUN_DIR"
    return 0
  fi

  set +e
  output="$(systemd-run --user --unit="$unit" --on-calendar="@$target_epoch" --timer-property=WakeSystem=true --setenv="PATH=$env_path" --working-directory="$CWD" /bin/bash -lc "$command_line" 2>&1)"
  status=$?
  set -e

  log_text "suspend-until-ready systemd-run status=$status output=$output"
  log_event "suspend_schedule_attempt" "$(jq -nc --arg unit "$unit" --argjson status "$status" --arg output "$output" --argjson target_epoch "$target_epoch" '{unit:$unit,status:$status,output:$output,target_epoch:$target_epoch}')"
  if (( status != 0 )); then
    return 1
  fi

  # Verify the timer is actually active before suspending.
  if ! systemctl --user is-active --quiet "${unit}.timer" 2>/dev/null; then
    log_text "suspend-until-ready timer ${unit}.timer not active after systemd-run; aborting suspend"
    log_event "suspend_schedule_failed" "$(jq -nc --arg unit "$unit" '{reason:"timer-not-active",unit:$unit}')"
    return 1
  fi

  if [[ "${LLM_SCHEDULER_NO_ACTUAL_SUSPEND:-0}" == "1" ]]; then
    log_text "suspend skipped by LLM_SCHEDULER_NO_ACTUAL_SUSPEND=1"
    log_event "suspend_skipped" '{"reason":"env"}'
    printf 'scheduled: logs written to %s\n' "$RUN_DIR"
    return 0
  fi

  # Install Ctrl-C / SIGTERM cleanup so the armed timer is stopped if the user
  # cancels during the pre-suspend countdown.
  _suspend_unit="$unit"
  # shellcheck disable=SC2317  # Called indirectly by the trap below.
  _suspend_cleanup() {
    local cleanup_status=0
    printf '\nsuspend cancelled: disarming timer %s.timer\n' "$_suspend_unit"
    systemctl --user stop "${_suspend_unit}.timer" 2>/dev/null || cleanup_status=$?
    if (( cleanup_status != 0 )); then
      printf 'WARNING: timer stop may have failed. To disarm manually:\n'
      printf '  systemctl --user stop %s.timer\n' "$_suspend_unit"
    fi
    exit 130
  }
  trap '_suspend_cleanup' INT TERM

  print_pre_suspend_confirmation "$target_epoch" "$unit" "$reason"
  log_event "pre_suspend_confirmation" "$(jq -nc --arg unit "$unit" --arg reason "$reason" --argjson target_epoch "$target_epoch" --arg model "$(scheduler_model_description)" --arg prompt "$PROMPT_SOURCE" --arg cwd "$CWD" --argjson seconds "$PRE_SUSPEND_CONFIRMATION_SECONDS" '{unit:$unit,reason:$reason,target_epoch:$target_epoch,model:$model,prompt:$prompt,cwd:$cwd,seconds:$seconds}')"

  trap - INT TERM

  log_text "systemctl suspend requested"
  sync
  systemctl suspend
  printf 'scheduled: logs written to %s\n' "$RUN_DIR"
}

wait_until_usable() {
  local not_before snapshot decision usable wait_until reason now target
  local undetermined_since="" waited
  not_before="$(parse_not_before_epoch)"
  while true; do
    now="$(now_epoch)"
    if (( now < not_before )); then
      log_text "not-before gate active until $not_before"
      log_event "wait_decision" "$(jq -nc --arg reason "not-before" --argjson wait_until "$not_before" '{reason:$reason,wait_until:$wait_until}')"
      log_wake_plan "$not_before"
      if (( SUSPEND_UNTIL_READY == 1 )); then
        if schedule_resume_and_suspend "$not_before" "not-before"; then
          log_event "final" '{"status":"scheduled"}'
          exit 0
        else
          printf 'error: suspend scheduling failed; falling back to in-process wait\n' >&2
          log_event "suspend_schedule_fallback" '{"reason":"schedule_resume_and_suspend failed","gate":"not-before"}'
        fi
      fi
      if (( DRY_RUN == 1 )); then
        return 0
      fi
      sleep_until "$not_before"
    fi

    snapshot="$(scheduler_usage_snapshot)"
    log_event "usage_snapshot" "$snapshot"
    decision="$(usage_decision "$snapshot")"
    log_event "usage_decision" "$decision"
    usable="$(jq -r '.usable' <<<"$decision")"
    reason="$(jq -r '.reason' <<<"$decision")"
    wait_until="$(jq -r '.wait_until // empty' <<<"$decision")"
    log_text "usage decision: $reason"
    if [[ "$usable" == "true" ]]; then
      return 0
    fi

    # When usage cannot be measured (no network, transient API failure,
    # inconclusive/unsupported data) we must not block forever: a scheduled run
    # armed for a window reset would otherwise never fire if the probe is down
    # right after resume-from-suspend. Bound the wait, then proceed optimistically
    # and let the tool's own rate-limit handling and --retry-delays cover the rare
    # case where we were actually still limited. A known rate-limit (with a real
    # reset epoch) is excluded and still waits precisely.
    if is_undetermined_reason "$reason"; then
      [[ -n "$undetermined_since" ]] || undetermined_since="$now"
      waited=$(( now - undetermined_since ))
      if (( MAX_UNAVAILABLE_WAIT > 0 )) && (( waited >= MAX_UNAVAILABLE_WAIT )); then
        log_text "usage undeterminable for ${waited}s (reason=$reason); proceeding optimistically"
        log_event "optimistic_proceed" "$(jq -nc --arg reason "$reason" --argjson waited "$waited" --argjson max "$MAX_UNAVAILABLE_WAIT" '{reason:$reason,waited:$waited,max_unavailable_wait:$max}')"
        return 0
      fi
      if (( SUSPEND_UNTIL_READY == 1 )); then
        # There is no real reset epoch to sleep to; re-suspending on the short
        # poll interval would just churn the machine awake repeatedly. Launch now.
        log_text "usage undeterminable (reason=$reason) in suspend mode; proceeding optimistically instead of suspend-polling"
        log_event "optimistic_proceed" "$(jq -nc --arg reason "$reason" --argjson waited "$waited" --argjson max "$MAX_UNAVAILABLE_WAIT" '{reason:$reason,waited:$waited,max_unavailable_wait:$max,suspend_mode:true}')"
        return 0
      fi
    else
      undetermined_since=""
    fi

    target="${wait_until:-$(( $(now_epoch) + POLL_INTERVAL ))}"
    log_wake_plan "$target"
    if (( SUSPEND_UNTIL_READY == 1 )); then
      if schedule_resume_and_suspend "$target" "$reason"; then
        log_event "final" '{"status":"scheduled"}'
        exit 0
      else
        printf 'error: suspend scheduling failed; falling back to in-process wait\n' >&2
        log_event "suspend_schedule_fallback" "$(jq -nc --arg reason "$reason" '{reason:"schedule_resume_and_suspend failed",gate:$reason}')"
      fi
    fi
    if (( DRY_RUN == 1 )); then
      return 0
    fi
    sleep_until "$target"
  done
}

main() {
  parse_args "$@"
  validate_args
  if [[ "$WAKE_TEST" -eq 1 ]]; then
    print_wake_test
    exit 0
  fi
  need jq
  need date
  need sha256sum
  need awk
  need python3
  setup_run_logs "${TOOL:-wake}" "${TOOL:-}"
  load_prompt
  log_text "start provider=$TOOL cwd=$CWD"
  log_event "start" "$(safe_args_json)"
  log_event "prompt" "$(jq -nc --arg source "$PROMPT_SOURCE" --arg sha256 "$PROMPT_SHA" --rawfile prompt "$RUN_DIR/prompt.txt" '{source:$source,sha256:$sha256,prompt:$prompt}')"

  wait_until_usable
  local argv_json
  argv_json="$(command_argv_json)"
  log_event "resolved_command" "$(jq -nc --argjson argv "$argv_json" '{argv:$argv}')"
  if (( DRY_RUN == 1 )); then
    log_text "dry-run complete"
    log_event "final" '{"status":"dry-run"}'
    printf 'dry-run: logs written to %s\n' "$RUN_DIR"
    exit 0
  fi

  retry_delays_array "$RETRY_DELAYS"
  local attempt=1 delay
  if submit_once "$attempt" "$argv_json"; then
    log_text "final status: success"
    log_event "final" '{"status":"success"}'
    printf 'success: logs written to %s\n' "$RUN_DIR"
    exit 0
  fi

  for delay in "${RETRY_ARRAY[@]}"; do
    log_text "retry after ${delay}s"
    log_event "retry" "$(jq -nc --argjson attempt "$attempt" --argjson delay "$delay" '{after_attempt:$attempt,delay:$delay}')"
    sleep "$delay"
    attempt=$(( attempt + 1 ))
    if submit_once "$attempt" "$argv_json"; then
      log_text "final status: success"
      log_event "final" '{"status":"success"}'
      printf 'success: logs written to %s\n' "$RUN_DIR"
      exit 0
    fi
  done
  log_text "final status: failed"
  log_event "final" '{"status":"failed"}'
  printf 'failed: logs written to %s\n' "$RUN_DIR" >&2
  exit 1
}

main "$@"
