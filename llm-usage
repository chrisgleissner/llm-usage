#!/usr/bin/env bash
# SPDX-License-Identifier: Apache-2.0
set -euo pipefail

# llm-usage: show remaining usage for Codex, Claude Code, and GitHub Copilot.
#
# Data sources:
#   Codex:  latest rate_limits/rateLimits object found in ~/.codex/sessions/**/*.jsonl
#   Claude: latest cached statusline JSON written by this script, then ~/.claude/projects/**/*.jsonl fallback
#   Copilot: local Copilot CLI screen footer captured in a pseudo-terminal
#
# Optional Claude Code integration:
#   Configure this script as your Claude Code statusLine command. When Claude Code sends
#   statusline JSON on stdin, this script caches it and prints a compact statusline.
#
# Dependencies: bash, curl, jq, find, sort, tail, date
# Optional for Copilot capture: timeout and python3/python

APP_NAME="llm-usage"
SCRIPT_PATH="$(readlink -f "$0" 2>/dev/null || printf '%s' "$0")"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/llm-usage"
CLAUDE_CACHE="$CACHE_DIR/claude-status.json"
CLAUDE_API_CACHE="$CACHE_DIR/claude-usage-api.json"
USAGE_LOG_FILE="$SCRIPT_DIR/llm-usage.log"
USAGE_LOG_TAIL_LINES="${LLM_USAGE_LOG_TAIL_LINES:-20000}"
WATCH_INTERVAL=0
JSON_OUTPUT=0
STATUSLINE_MODE=0
NO_HEADER=0
SHOW_COPILOT_CREDITS=0
SHOW_SOURCE="${LLM_USAGE_SHOW_SOURCE:-0}"
SHOW_REMAINING_TIME="${LLM_USAGE_SHOW_REMAINING_TIME:-1}"
SHOW_CODEX_SPARK="${LLM_USAGE_SHOW_CODEX_SPARK:-1}"
COPILOT_MONTHLY_RESET_OFFSET_DAYS="${LLM_USAGE_COPILOT_MONTHLY_RESET_OFFSET_DAYS:-0}"
LOG_ENABLED=0
COLOR_ENABLED=0
TOOL_COL_WIDTH=14
TABLE_GAP_WIDTH=3
RED=''
YELLOW=''
GREEN=''
RESET=''

# shellcheck source=lib/llm-common.sh
. "$SCRIPT_DIR/lib/llm-common.sh"

if [[ -t 1 && -z "${LLM_USAGE_NO_COLOR:-}" && "${TERM:-}" != "dumb" ]]; then
  COLOR_ENABLED=1
  RED=$'\033[0;31m'
  YELLOW=$'\033[0;33m'
  GREEN=$'\033[0;32m'
  RESET=$'\033[0m'
fi

usage() {
  cat <<USAGE
Usage: $APP_NAME [--json] [--watch SECONDS] [--show-copilot-credits] [--statusline] [--no-header]

Shows remaining percentage for:
  - Codex current session / 5-hour window
  - Codex Spark current session / 5-hour window
  - Codex weekly / 7-day window
  - Codex Spark weekly / 7-day window
  - Claude Code current session / 5-hour window
  - Claude Code weekly / 7-day window
  - Copilot monthly usage
  - Copilot AI credits (optional, with --show-copilot-credits)

Options:
  --json              Emit JSON instead of a table.
  -w, --watch SECONDS  Refresh repeatedly.
  --show-copilot-credits  Show Copilot AI credits row.
  --show-source         Show Source column. By default, Source is hidden.
  --hide-source         Hide Source column (default).
  --show-remaining-time  Show Remaining Time column (default).
  --hide-remaining-time Hide Remaining Time column.
  --show-codex-spark    Show Codex Spark rows (default).
  --hide-codex-spark    Hide Codex Spark rows.
  --copilot-monthly-reset-offset-days DAYS  Day offset from month start for Copilot monthly reset (default: 0).
  --statusline        Read Claude Code statusline JSON from stdin, cache it, print compact line.
  --no-header         Omit table header.
  -h, --help          Show this help.
USAGE
}

# need() and other shared helpers come from lib/llm-common.sh (sourced above).

while [[ $# -gt 0 ]]; do
  case "$1" in
    --json) JSON_OUTPUT=1; shift ;;
    -w|--watch)
      [[ $# -ge 2 ]] || { err "$1 requires seconds"; exit 2; }
      WATCH_INTERVAL="$2"; shift 2 ;;
    --show-copilot-credits) SHOW_COPILOT_CREDITS=1; shift ;;
    --show-source) SHOW_SOURCE=1; shift ;;
    --hide-source) SHOW_SOURCE=0; shift ;;
    --show-remaining-time) SHOW_REMAINING_TIME=1; shift ;;
    --hide-remaining-time) SHOW_REMAINING_TIME=0; shift ;;
    --show-codex-spark) SHOW_CODEX_SPARK=1; shift ;;
    --hide-codex-spark) SHOW_CODEX_SPARK=0; shift ;;
    --copilot-monthly-reset-offset-days)
      [[ $# -ge 2 ]] || { err "--copilot-monthly-reset-offset-days requires DAYS"; exit 2; }
      COPILOT_MONTHLY_RESET_OFFSET_DAYS="$2"
      shift 2 ;;
    --statusline) STATUSLINE_MODE=1; shift ;;
    --no-header) NO_HEADER=1; shift ;;
    -h|--help) usage; exit 0 ;;
    *) err "unknown option: $1"; usage >&2; exit 2 ;;
  esac
done

if ! [[ "$COPILOT_MONTHLY_RESET_OFFSET_DAYS" =~ ^-?[0-9]+$ ]]; then
  err "--copilot-monthly-reset-offset-days expects an integer"
  exit 2
fi

if [[ "$WATCH_INTERVAL" != "0" ]] && ! is_number "$WATCH_INTERVAL"; then
  err "--watch requires numeric seconds"
  exit 2
fi

need jq
need curl
need find
need sort
need tail
need date
mkdir -p "$CACHE_DIR"

if :>> "$USAGE_LOG_FILE" 2>/dev/null; then
  LOG_ENABLED=1
fi

colorize_percent() {
  local value="${1:-}"
  if [[ "$COLOR_ENABLED" -ne 1 ]]; then
    printf '%s' "$value"
    return
  fi

  case "$value" in
    -|unavailable|unknown|"") printf '%s' "$value"; return;;
  esac

  local numeric="${value%\%}"
  if [[ ! "$numeric" =~ ^[0-9]+([.][0-9]+)?$ ]]; then
    printf '%s' "$value"
    return
  fi

  local integer="${numeric%.*}"
  [[ -z "$integer" ]] && integer="0"

  if (( integer < 10 )); then
    printf '%s%s%s' "$RED" "$value" "$RESET"
  elif (( integer < 30 )); then
    printf '%s%s%s' "$YELLOW" "$value" "$RESET"
  else
    printf '%s%s%s' "$GREEN" "$value" "$RESET"
  fi
}

print_cell() {
  local width="$1"
  local text="$2"
  local plain
  plain=$(printf '%s' "$text" | sed -E 's/\x1b\[[0-9;]*[A-Za-z]//g')
  local pad=$((width - ${#plain}))
  printf '%s' "$text"
  if (( pad > 0 )); then
    printf '%*s' "$pad" ''
  fi
}

print_table_cell() {
  local width="$1"
  local text="$2"
  local add_gap="${3:-0}"
  print_cell "$width" "$text"
  if [[ "$add_gap" == "1" ]]; then
    printf '%*s' "$TABLE_GAP_WIDTH" ''
  fi
}

print_header_cell() {
  local width="$1"
  local text="$2"
  local add_gap="${3:-0}"
  printf '%-*s' "$width" "$text"
  if [[ "$add_gap" == "1" ]]; then
    printf '%*s' "$TABLE_GAP_WIDTH" ''
  fi
}

print_rule_cell() {
  local width="$1"
  local add_gap="${2:-0}"
  printf '%*s' "$width" '' | tr ' ' '-'
  if [[ "$add_gap" == "1" ]]; then
    printf '%*s' "$TABLE_GAP_WIDTH" ''
  fi
}

format_tool_name() {
  local name="${1:-}"
  case "$name" in
    GPT-5.3-Codex-Spark|*GPT-5.3*Codex*Spark*)
      printf 'GPT-5.3 Spark'
      ;;
    *)
      printf '%s' "$name"
      ;;
  esac
}

print_value_row() {
  local provider="$1"
  local window="$2"
  local remaining="$3"
  local remaining_time="$4"
  local reset_text="$5"
  local time_to_reset="$6"
  local source="$7"
  local remaining_colored

  remaining_colored=$(colorize_percent "$remaining")
  print_table_cell "$TOOL_COL_WIDTH" "$provider" 1
  print_table_cell 12 "$window" 1
  print_table_cell 11 "$remaining_colored" 1

  if [[ "$SHOW_REMAINING_TIME" -eq 1 ]]; then
    print_table_cell 14 "$remaining_time" 1
  fi

  print_table_cell 16 "$reset_text" 1
  if [[ "$SHOW_SOURCE" -eq 1 ]]; then
    print_table_cell 12 "$time_to_reset" 1
    printf '%s' "$source"
  else
    print_table_cell 12 "$time_to_reset" 0
  fi
  printf '\n'
}

print_row() {
  local provider="$1"
  local window="$2" used="$3" reset="$4" source="$5"
  local display_provider="${6:-$1}"
  local remaining remaining_time reset_text time_to_reset
  remaining=$(remaining_from_used "$used")
  [[ -n "$remaining" ]] || remaining="-"
  remaining_time="-"
  if [[ "$SHOW_REMAINING_TIME" -eq 1 ]]; then
    remaining_time=$(estimate_remaining_time_from_log "$provider" "$window" "$remaining")
    [[ -n "$remaining_time" ]] || remaining_time="-"
  fi

  reset_text=$(fmt_reset "$reset")
  [[ -n "$reset_text" ]] || reset_text="-"
  time_to_reset=$(time_until "$reset")

  local fmt_remaining
  fmt_remaining="$(fmt_pct "$remaining")"
  if [[ "$fmt_remaining" == "-" || "$fmt_remaining" == "unknown" ]]; then
    print_value_row "$display_provider" "$window" "$fmt_remaining" "$remaining_time" "$reset_text" "$time_to_reset" "$source"
  else
    print_value_row "$display_provider" "$window" "${fmt_remaining}%" "$remaining_time" "$reset_text" "$time_to_reset" "$source"
  fi
}

log_and_print_row() {
  local provider="$1" window="$2" used="$3" reset="$4" source="$5"
  local display_provider="${6:-$provider}"
  local remaining
  remaining=$(remaining_from_used "$used")
  if [[ "$LOG_ENABLED" -eq 1 ]]; then
    log_usage_sample "$provider" "$window" "$remaining"
  fi
  print_row "$provider" "$window" "$used" "$reset" "$source" "$display_provider"
}

print_unavailable_rows() {
  local provider="$1"
  if [[ "$SHOW_REMAINING_TIME" -eq 1 ]]; then
    print_value_row "$provider" "5h" "-" "-" "-" "-" "no local data"
    print_value_row "$provider" "weekly" "-" "-" "-" "-" "no local data"
  else
    print_value_row "$provider" "5h" "-" "" "-" "-" "no local data"
    print_value_row "$provider" "weekly" "-" "" "-" "-" "no local data"
  fi
}

print_codex_rows() {
  local codex_json="$1"
  if [[ -z "$codex_json" ]]; then
    print_unavailable_rows "Codex"
    return
  fi

  local rows_count row
  rows_count=$(jq -r '(if (.rows|type=="array") then .rows | length else 0 end)' <<<"$codex_json" 2>/dev/null || echo 0)
  if [[ "$rows_count" == "0" ]]; then
    log_and_print_row "Codex" "5h" "$(jq -r '.five_hour.used // empty' <<<"$codex_json")" "$(jq -r '.five_hour.resets_at // empty' <<<"$codex_json")" "$(jq -r '.source // empty' <<<"$codex_json")"
    log_and_print_row "Codex" "weekly" "$(jq -r '.week.used // empty' <<<"$codex_json")" "$(jq -r '.week.resets_at // empty' <<<"$codex_json")" "$(jq -r '.source // empty' <<<"$codex_json")"
    return
  fi

  while IFS= read -r row; do
    local row_key provider source row_is_spark display_provider
    row_key=$(jq -r '.key // "codex"' <<<"$row")
    provider=$(jq -r '.name // "Codex"' <<<"$row")
    display_provider=$(format_tool_name "$provider")
    row_is_spark=0
    if [[ "$row_key" == "codex-spark" || "${provider,,}" == *spark* ]]; then
      row_is_spark=1
    fi
    if (( SHOW_CODEX_SPARK == 0 && row_is_spark == 1 )); then
      continue
    fi

    source=$(jq -r '.source // empty' <<<"$row")
    [[ -n "$source" ]] || source=$(jq -r '.source // empty' <<<"$codex_json")

    log_and_print_row "$provider" "5h" "$(jq -r '.five_hour.used // empty' <<<"$row")" "$(jq -r '.five_hour.resets_at // empty' <<<"$row")" "$source" "$display_provider"
    log_and_print_row "$provider" "weekly" "$(jq -r '.week.used // empty' <<<"$row")" "$(jq -r '.week.resets_at // empty' <<<"$row")" "$source" "$display_provider"
  done < <(jq -c '.rows[]' <<<"$codex_json")

}

print_copilot_rows() {
  local copilot_json="$1"
  local source monthly_remaining monthly_remaining_raw ai_credits
  local copilot_reset_ts copilot_reset copilot_to_reset

  copilot_reset_ts="$(copilot_monthly_reset_epoch)"
  copilot_reset="$(fmt_reset "$copilot_reset_ts")"
  if [[ -z "$copilot_reset" ]]; then
    copilot_reset="-"
  fi
  copilot_to_reset="$(time_until "$copilot_reset_ts")"
  [[ -n "$copilot_to_reset" ]] || copilot_to_reset="-"

  if [[ -z "$copilot_json" ]]; then
      if [[ "$SHOW_REMAINING_TIME" -eq 1 ]]; then
        print_value_row "Copilot" "monthly" "unavailable" "-" "$copilot_reset" "$copilot_to_reset" "copilot cli"
      else
        print_value_row "Copilot" "monthly" "unavailable" "" "$copilot_reset" "$copilot_to_reset" "copilot cli"
      fi
    if [[ "$SHOW_COPILOT_CREDITS" -eq 1 ]]; then
      if [[ "$SHOW_REMAINING_TIME" -eq 1 ]]; then
        print_value_row "Copilot" "ai-credits" "unavailable" "-" "-" "-" "copilot cli"
      else
        print_value_row "Copilot" "ai-credits" "unavailable" "" "-" "-" "copilot cli"
      fi
    fi
    return
  fi

  source=$(jq -r '.source // "copilot cli"' <<<"$copilot_json")
  if [[ "$(jq -r 'if .available? == false then "false" else "true" end' <<<"$copilot_json")" == "false" ]]; then
    if [[ "$SHOW_REMAINING_TIME" -eq 1 ]]; then
      print_value_row "Copilot" "monthly" "unavailable" "-" "$copilot_reset" "$copilot_to_reset" "$source"
    else
      print_value_row "Copilot" "monthly" "unavailable" "" "$copilot_reset" "$copilot_to_reset" "$source"
    fi
    if [[ "$SHOW_COPILOT_CREDITS" -eq 1 ]]; then
      if [[ "$SHOW_REMAINING_TIME" -eq 1 ]]; then
        print_value_row "Copilot" "ai-credits" "unavailable" "-" "-" "-" "$source"
      else
        print_value_row "Copilot" "ai-credits" "unavailable" "" "-" "-" "$source"
      fi
    fi
    return
  fi

  monthly_remaining=$(jq -r '.monthly.remaining // empty' <<<"$copilot_json")
  local monthly_remaining_raw="$monthly_remaining"
  ai_credits=$(jq -r '.ai_credits.used // empty' <<<"$copilot_json")

  if [[ -n "$monthly_remaining" ]]; then
    monthly_remaining="$(fmt_pct "$monthly_remaining")%"
  else
    # No monthly figure: the JSON path reports the provider as available:false in
    # this case, so the table must not imply a usable value here.
    monthly_remaining="unavailable"
  fi
  if [[ "$LOG_ENABLED" -eq 1 ]]; then
    log_usage_sample "copilot" "monthly" "$monthly_remaining_raw"
  fi

  if [[ "$SHOW_REMAINING_TIME" -eq 1 ]]; then
    print_value_row "Copilot" "monthly" "$monthly_remaining" "$(estimate_remaining_time_from_log copilot monthly "$monthly_remaining_raw")" "$copilot_reset" "$copilot_to_reset" "$source"
  else
    print_value_row "Copilot" "monthly" "$monthly_remaining" "" "$copilot_reset" "$copilot_to_reset" "$source"
  fi
  if [[ "$SHOW_COPILOT_CREDITS" -eq 1 ]]; then
    [[ -n "$ai_credits" ]] || ai_credits="unknown"
    if [[ "$SHOW_REMAINING_TIME" -eq 1 ]]; then
      print_value_row "Copilot" "ai-credits" "$ai_credits" "-" "-" "-" "$source"
    else
      print_value_row "Copilot" "ai-credits" "$ai_credits" "" "-" "-" "$source"
    fi
  fi
}

render_once() {
  local codex claude copilot codex_json claude_json copilot_json
  codex=$(read_codex || true)
  claude=$(read_claude || true)
  copilot=$(read_copilot || true)

  if [[ "$JSON_OUTPUT" -eq 1 ]]; then
    codex_json=$(json_for_provider "$codex" codex)
    claude_json=$(json_for_provider "$claude" claude)
    copilot_json=$(json_for_copilot "$copilot" "$SHOW_COPILOT_CREDITS")
    jq -nc --arg generated_at "$(date -Is)" --argjson codex "$codex_json" --argjson claude "$claude_json" --argjson copilot "$copilot_json" \
      '{generated_at:$generated_at, codex:$codex, claude:$claude, copilot:$copilot}'
    return
  fi

  if [[ "$NO_HEADER" -eq 0 ]]; then
    if [[ "$SHOW_REMAINING_TIME" -eq 1 ]]; then
      if [[ "$SHOW_SOURCE" -eq 1 ]]; then
        print_header_cell "$TOOL_COL_WIDTH" "Tool" 1
        print_header_cell 12 "Window" 1
        print_header_cell 11 "Remaining" 1
        print_header_cell 14 "Remaining Time" 1
        print_header_cell 16 "Resets" 1
        print_header_cell 12 "Time to Reset" 1
        printf 'Source\n'
        print_rule_cell "$TOOL_COL_WIDTH" 1
        print_rule_cell 12 1
        print_rule_cell 11 1
        print_rule_cell 14 1
        print_rule_cell 16 1
        print_rule_cell 12 1
        printf '%*s\n' "$TABLE_GAP_WIDTH" '' | tr ' ' '-'
      else
        print_header_cell "$TOOL_COL_WIDTH" "Tool" 1
        print_header_cell 12 "Window" 1
        print_header_cell 11 "Remaining" 1
        print_header_cell 14 "Remaining Time" 1
        print_header_cell 16 "Resets" 1
        print_header_cell 12 "Time to Reset" 0
        printf '\n'
        print_rule_cell "$TOOL_COL_WIDTH" 1
        print_rule_cell 12 1
        print_rule_cell 11 1
        print_rule_cell 14 1
        print_rule_cell 16 1
        print_rule_cell 12 0
        printf '\n'
      fi
    else
      if [[ "$SHOW_SOURCE" -eq 1 ]]; then
        print_header_cell "$TOOL_COL_WIDTH" "Tool" 1
        print_header_cell 12 "Window" 1
        print_header_cell 11 "Remaining" 1
        print_header_cell 16 "Resets" 1
        printf 'Source\n'
        print_rule_cell "$TOOL_COL_WIDTH" 1
        print_rule_cell 12 1
        print_rule_cell 11 1
        print_rule_cell 16 1
        printf '%*s\n' "$TABLE_GAP_WIDTH" '' | tr ' ' '-'
      else
        print_header_cell "$TOOL_COL_WIDTH" "Tool" 1
        print_header_cell 12 "Window" 1
        print_header_cell 11 "Remaining" 1
        print_header_cell 16 "Resets" 0
        printf '\n'
        print_rule_cell "$TOOL_COL_WIDTH" 1
        print_rule_cell 12 1
        print_rule_cell 11 1
        print_rule_cell 16 0
        printf '\n'
      fi
    fi
  fi

  print_codex_rows "$codex"

  if [[ -n "$claude" ]]; then
    log_and_print_row "Claude" "5h" "$(jq -r '.five_hour.used // empty' <<<"$claude")" "$(jq -r '.five_hour.resets_at // empty' <<<"$claude")" "$(jq -r '.source' <<<"$claude")"
    log_and_print_row "Claude" "weekly" "$(jq -r '.week.used // empty' <<<"$claude")"      "$(jq -r '.week.resets_at // empty' <<<"$claude")"      "$(jq -r '.source' <<<"$claude")"
  else
    print_unavailable_rows "Claude"
  fi

  print_copilot_rows "$copilot"
}

statusline_mode() {
  local input five week five_rem week_rem out
  input=$(cat)
  if jq -e '.rate_limits? // .rateLimits?' >/dev/null 2>&1 <<<"$input"; then
    printf '%s\n' "$input" > "$CLAUDE_CACHE"
  fi

  five=$(jq -r '.rate_limits.five_hour.used_percentage // .rateLimits.fiveHour.usedPercent // empty' <<<"$input" 2>/dev/null || true)
  week=$(jq -r '.rate_limits.seven_day.used_percentage // .rateLimits.sevenDay.usedPercent // empty' <<<"$input" 2>/dev/null || true)
  five_rem=$(remaining_from_used "$five")
  week_rem=$(remaining_from_used "$week")

  out="Claude"
  [[ -n "$five_rem" ]] && out="$out 5h ${five_rem}% left"
  [[ -n "$week_rem" ]] && out="$out weekly ${week_rem}% left"
  printf '%s\n' "$out"
}

render_once_frame() {
  local frame_now="$1"
  {
    printf 'Last refreshed: %s\n' "$frame_now"
    render_once
  }
}

if [[ "$STATUSLINE_MODE" -eq 1 ]]; then
  statusline_mode
  exit 0
fi

if [[ "$WATCH_INTERVAL" != "0" ]]; then
  watch_frame=""
  refresh_time=""
  while true; do
    refresh_time="$(date '+%Y-%m-%d %H:%M:%S')"
    watch_frame="$(render_once_frame "$refresh_time")"
    if [[ -t 1 ]]; then
      printf '\033[2J\033[H'
    fi
    printf '%s' "$watch_frame"
    sleep "$WATCH_INTERVAL"
  done
else
  render_once
fi
